<%- include('partials/header') %>

<main class="home-page">
  <section class="home-hero" id="home" aria-labelledby="home-hero-title">
    <div class="home-container home-hero__inner">
      <div class="home-hero__copy">
        <p class="home-kicker"><%= copy.home.kicker %></p>
        <h1 id="home-hero-title"><%= copy.home.title %></h1>
        <p class="home-hero__lead">
          <strong><%= copy.home.leadStrong %></strong>
          <%= copy.home.lead %>
        </p>

        <div class="home-hero__cta-stack">
          <div class="home-actions" aria-label="<%= copy.home.getStartedLabel %>">
            <a href="/chat?guest=1" class="home-button home-button--primary"><span><%= copy.common.tryAsGuest %></span></a>
            <a href="/register" class="home-button home-button--outline"><span><%= copy.common.createAccount %></span></a>
          </div>

          <ul class="home-trust-list" aria-label="<%= copy.home.highlightsLabel %>">
            <% copy.home.highlights.forEach((highlight) => { %><li><%= highlight %></li><% }) %>
          </ul>
        </div>
      </div>

      <div class="home-match-preview" aria-label="<%= copy.home.preview.aria %>">
        <div class="home-match-preview__header">
          <div>
            <span class="home-preview-label"><%= copy.home.preview.label %></span>
            <strong><%= copy.home.preview.headline %></strong>
          </div>
          <span class="home-live-status"><span aria-hidden="true"></span><%= copy.home.preview.searching %></span>
        </div>

        <div class="home-signal-network">
          <article class="home-signal-node">
            <div class="home-signal-node__identity">
              <span class="home-avatar" aria-hidden="true">Y</span>
              <div>
                <strong><%= copy.home.preview.yourSignal %></strong>
                <p><%= copy.home.preview.yourStatus %></p>
              </div>
            </div>
            <div class="home-topic-list" aria-label="<%= copy.home.preview.yourInterestsAria %>">
              <span><%= copy.home.sampleTopics.webDevelopment %></span>
              <span><%= copy.home.sampleTopics.photography %></span>
            </div>
          </article>

          <div class="home-signal-bridge" aria-hidden="true">
            <span class="home-signal-bridge__line"></span>
            <small><%= copy.home.preview.shared %></small>
          </div>

          <article class="home-signal-node">
            <div class="home-signal-node__identity">
              <span class="home-avatar home-avatar--match" aria-hidden="true">M</span>
              <div>
                <strong><%= copy.home.preview.match %></strong>
                <p><%= copy.home.preview.matchStatus %></p>
              </div>
            </div>
            <div class="home-topic-list" aria-label="<%= copy.home.preview.matchInterestsAria %>">
              <span><%= copy.home.sampleTopics.webDevelopment %></span>
              <span><%= copy.home.sampleTopics.travel %></span>
            </div>
          </article>
        </div>

        <div class="home-conversation-signal">
          <span class="home-conversation-signal__dot" aria-hidden="true"></span>
          <div>
            <strong><%= copy.home.preview.ready %></strong>
            <p><%= copy.home.preview.readyBody %></p>
          </div>
          <span class="home-ready-pill"><%= copy.home.preview.readyPill %></span>
        </div>
      </div>

    </div>
  </section>

  <div class="home-divider" aria-hidden="true"></div>

  <section class="home-capabilities" id="features" aria-labelledby="home-features-title">
    <div class="home-container">
      <header class="home-section-header">
        <p class="home-kicker"><%= copy.home.featuresSection.kicker %></p>
        <h2 id="home-features-title"><%= copy.home.featuresSection.title %></h2>
        <p><%= copy.home.featuresSection.intro %></p>
      </header>

      <div class="home-capability-grid">
        <article class="home-capability home-capability--lead">
          <div class="home-capability-visual" aria-hidden="true">
            <span class="home-orbit home-orbit--outer"></span>
            <span class="home-orbit home-orbit--inner"></span>
            <span class="home-orbit-topic home-orbit-topic--top"><%= copy.home.sampleTopics.designSystems %></span>
            <span class="home-orbit-topic home-orbit-topic--right"><%= copy.home.sampleTopics.photography %></span>
            <span class="home-orbit-topic home-orbit-topic--bottom"><%= copy.home.sampleTopics.webApps %></span>
            <span class="home-orbit-core"><%= copy.home.featuresSection.sharedSignal %></span>
          </div>
          <div>
            <p class="home-capability__label"><%= copy.home.featuresSection.items[0].label %></p>
            <h3><%= copy.home.featuresSection.items[0].title %></h3>
            <p><%= copy.home.featuresSection.items[0].body %></p>
          </div>
        </article>

        <article class="home-capability home-capability--safety">
          <p class="home-capability__label"><%= copy.home.featuresSection.items[1].label %></p>
          <h3><%= copy.home.featuresSection.items[1].title %></h3>
          <p><%= copy.home.featuresSection.items[1].body %></p>
        </article>

        <article class="home-capability home-capability--privacy">
          <p class="home-capability__label"><%= copy.home.featuresSection.items[2].label %></p>
          <h3><%= copy.home.featuresSection.items[2].title %></h3>
          <p><%= copy.home.featuresSection.items[2].body %></p>
        </article>

        <article class="home-capability home-capability--instant">
          <p class="home-capability__label"><%= copy.home.featuresSection.items[3].label %></p>
          <h3><%= copy.home.featuresSection.items[3].title %></h3>
          <p><%= copy.home.featuresSection.items[3].body %></p>
        </article>

        <article class="home-capability home-capability--formats">
          <p class="home-capability__label"><%= copy.home.featuresSection.items[4].label %></p>
          <h3><%= copy.home.featuresSection.items[4].title %></h3>
          <p><%= copy.home.featuresSection.items[4].body %></p>
        </article>

        <article class="home-capability home-capability--global">
          <p class="home-capability__label"><%= copy.home.featuresSection.items[5].label %></p>
          <h3><%= copy.home.featuresSection.items[5].title %></h3>
          <p><%= copy.home.featuresSection.items[5].body %></p>
        </article>
      </div>
    </div>
  </section>

  <div class="home-divider" aria-hidden="true"></div>

  <section class="home-journey" id="how-it-works" aria-labelledby="home-journey-title">
    <div class="home-container">
      <header class="home-section-header">
        <p class="home-kicker"><%= copy.home.journey.kicker %></p>
        <h2 id="home-journey-title"><%= copy.home.journey.title %></h2>
        <p><%= copy.home.journey.intro %></p>
      </header>

      <div class="home-journey-track" aria-label="<%= copy.home.journey.aria %>">
        <% copy.home.journey.steps.forEach((step) => { %>
          <article class="home-journey-stop">
            <span class="home-journey-cue"><%= step.cue %></span>
            <h3><%= step.title %></h3>
            <p><%= step.body %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>

  <div class="home-divider" aria-hidden="true"></div>

  <section class="home-invitation" aria-labelledby="home-invitation-title">
    <div class="home-container home-invitation__inner">
      <div>
        <p class="home-kicker"><%= copy.home.invitation.kicker %></p>
        <h2 id="home-invitation-title"><%= copy.home.invitation.title %></h2>
        <p><%= copy.home.invitation.body %></p>
      </div>
      <div class="home-actions home-invitation__actions">
        <a href="/chat?guest=1" class="home-button home-button--primary"><span><%= copy.common.tryAsGuest %></span></a>
        <a href="/register" class="home-button home-button--outline"><span><%= copy.common.createAccount %></span></a>
      </div>
    </div>
  </section>

  <div class="home-divider" aria-hidden="true"></div>
</main>

<%- include('partials/footer') %>
