<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> - Interest Chat</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Baloo+2:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="chat-app-page">
    <button class="mobile-sidebar-toggle" id="sidebarToggle" type="button" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="chat-layout">
      <aside class="chat-sidebar" id="chatSidebar">
        <a class="chat-brand" href="/">
          <span>IC</span>
          <strong>Interest Chat</strong>
        </a>

        <div class="chat-profile-card">
          <div class="chat-profile-avatar" id="profileInitial" aria-hidden="true">🍇</div>
          <div class="chat-profile-meta">
            <strong id="profileName">Guest</strong>
            <span>Guest Account</span>
          </div>
          <div class="chat-profile-actions">
            <button type="button" aria-label="Settings" title="Coming soon">
              <span class="ui-icon icon-gear"></span>
            </button>
            <button type="button" id="soundToggle" aria-label="Toggle sound">
              <span class="ui-icon icon-audio"></span>
            </button>
            <button type="button" id="themeToggle" aria-label="Toggle theme">
              <span class="ui-icon icon-moon"></span>
            </button>
            <button type="button" aria-label="Language" title="Coming soon">
              <span class="emoji-icon">🌐</span>
            </button>
          </div>
        </div>

        <div class="quick-actions-row">
          <button type="button" class="premium-badge" aria-label="Premium" title="Coming soon">
            <span class="emoji-icon">👑</span>
          </button>
          <button type="button" class="discord-new-chat" id="startBtnSidebar">
            <span class="ui-icon icon-chat"></span>
            Start New Chat
          </button>
        </div>

        <div class="discord-panel">
          <div class="sidebar-columns">
            <nav class="icon-rail" aria-label="Sections">
              <button type="button" class="active" data-panel="messages" aria-label="Messages" title="Messages">
                <span class="emoji-icon">💬</span>
              </button>
              <button type="button" data-panel="history" aria-label="History" title="History">
                <span class="emoji-icon">🕓</span>
              </button>
              <button type="button" data-panel="friends" aria-label="Friends" title="Friends">
                <span class="ui-icon icon-users"></span>
              </button>
              <button type="button" data-panel="notifications" aria-label="Notifications" title="Notifications">
                <span class="emoji-icon">🔔</span>
              </button>
              <button type="button" data-panel="saved" aria-label="Saved chats" title="Saved chats">
                <span class="emoji-icon">❤️</span>
              </button>
            </nav>

            <div class="discord-scroll">

              <!-- Pannello: Messages / Requests -->
              <div class="inbox-panel active" data-panel-content="messages">
                <div class="discord-tabs">
                  <button type="button" class="active" id="inboxTabMessages">Messages</button>
                  <button type="button" id="inboxTabRequests">Requests</button>
                </div>
                <div class="empty-inbox">
                  <div class="empty-icon"><span class="ui-icon icon-mailbox"></span></div>
                  <p>No conversations yet. Match with someone or add friends to start chatting!</p>
                </div>
              </div>

              <!-- Pannello: History -->
              <div class="inbox-panel" data-panel-content="history">
                <div class="inbox-panel-title">Recent chats</div>
                <div class="empty-inbox">
                  <div class="empty-icon"><span class="emoji-icon">🕓</span></div>
                  <p>Your chat history will appear here.</p>
                </div>
              </div>

              <!-- Pannello: Friends / Requests -->
              <div class="inbox-panel" data-panel-content="friends">
                <div class="discord-tabs">
                  <button type="button" class="active" id="friendsTabFriends">Friends</button>
                  <button type="button" id="friendsTabRequests">Requests</button>
                </div>
                <div class="empty-inbox">
                  <div class="empty-icon"><span class="ui-icon icon-users"></span></div>
                  <p>No friends yet. Add friends or accept a request.</p>
                </div>
              </div>

              <!-- Pannello: Notifications -->
              <div class="inbox-panel" data-panel-content="notifications">
                <div class="inbox-panel-title">Notifications</div>
                <div class="empty-inbox">
                  <div class="empty-icon"><span class="emoji-icon">🔔</span></div>
                  <p>No notifications yet.</p>
                </div>
              </div>

              <!-- Pannello: Saved chats -->
              <div class="inbox-panel" data-panel-content="saved">
                <div class="inbox-panel-title">Saved chats</div>
                <div class="empty-inbox">
                  <div class="empty-icon"><span class="emoji-icon">❤️</span></div>
                  <p>Chats you save will show up here.</p>
                </div>
              </div>

            </div>
          </div>
        </div>
      </aside>

      <main class="chat-main">
        <p class="chat-guideline">
          Chat with random people worldwide - Be respectful, have fun, and follow our <a href="/terms">community guidelines</a>
        </p>

        <div id="matchSetup" class="setup-stack">
          <section class="quick-start-card">
            <div class="quick-card-head">
              <div>
                <p class="panel-super">Quick start</p>
                <h1>Tell us who is chatting</h1>
              </div>
              <span class="quick-pill">Guest setup</span>
            </div>

            <div class="quick-form-grid">
              <label class="quick-field" for="usernameInput">
                <span>Your username</span>
                <input id="usernameInput" type="text" maxlength="24" autocomplete="nickname" placeholder="Enter your name">
              </label>

              <label class="quick-field" for="ageInput">
                <span>Your age</span>
                <select id="ageInput">
                  <option value="">Select age</option>
                  <% for (let age = 18; age <= 99; age++) { %>
                    <option value="<%= age %>"><%= age %></option>
                  <% } %>
                </select>
              </label>

              <label class="quick-field country-field" for="countryInput">
                <span>Your country</span>
                <input id="countryInput" type="text" autocomplete="off" placeholder="Select country">
                <input id="countryValue" type="hidden">
                <div class="country-suggestions hidden" id="countrySuggestions"></div>
              </label>
            </div>

            <label class="tos-check">
              <input id="tosInput" type="checkbox">
              <span>I agree to the <a href="/terms">ToS</a> and <a href="/privacy">privacy policy</a> and I'm at least 18 years old</span>
            </label>

            <p class="form-error hidden" id="quickStartError"></p>

            <div class="quick-login-line">
              Already have an account? <a href="/login">Log in</a>
            </div>
          </section>

          <section class="interest-panel collapsible-panel" data-collapsible>
            <div class="interest-panel-icon">
              <span class="ui-icon icon-list"></span>
            </div>
            <div class="interest-panel-content">
              <div class="interest-panel-head">
                <div>
                  <h2>Type your interests</h2>
                  <p>Optional. Add a few topics to improve the match.</p>
                  <span class="time-hint"><span class="emoji-icon">⏱</span> 10 sec</span>
                </div>
                <button class="collapse-dot" type="button" aria-label="Collapse interests">
                  <span class="ui-icon icon-arrow-down"></span>
                </button>
              </div>

              <div class="collapsible-body">
                <div class="interest-input wide">
                  <div class="interest-tags" id="interestTags"></div>
                  <input id="interestsInput" type="text" maxlength="30" placeholder="Add an interest and press Enter">
                  <button id="addInterestBtn" type="button" aria-label="Add interest">
                    <span class="ui-icon icon-check"></span>
                  </button>
                </div>

                <div class="wait-row">
                  <strong>Max wait time</strong>
                  <div class="pill-row">
                    <button type="button" class="pill" disabled>5 sec</button>
                    <button type="button" class="pill selected" disabled>10 sec</button>
                    <button type="button" class="pill" disabled>15 sec</button>
                    <button type="button" class="pill" disabled>30 sec</button>
                    <button type="button" class="pill" disabled>Unlimited</button>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="filter-card green collapsible-panel collapsed" data-collapsible>
            <div class="filter-icon">
              <span class="ui-icon icon-users"></span>
            </div>
            <div>
              <h2>Gender & Age Filter <span>♕</span></h2>
              <p>Find people matching your preferences.</p>
              <div class="collapsible-body">
                <div class="locked-filter-copy">Coming soon as a premium filter.</div>
              </div>
            </div>
            <button type="button" aria-label="Open filter">
              <span class="ui-icon icon-arrow-right"></span>
            </button>
          </section>

          <section class="filter-card blue collapsible-panel collapsed" data-collapsible>
            <div class="filter-icon">
              <span class="ui-icon icon-pin"></span>
            </div>
            <div>
              <h2>Filter by Country & Location <span>♕</span></h2>
              <p>Select country or location you want to connect within.</p>
              <div class="collapsible-body">
                <div class="locked-filter-copy">Coming soon as a premium filter.</div>
              </div>
            </div>
            <button type="button" aria-label="Open filter">
              <span class="ui-icon icon-arrow-right"></span>
            </button>
          </section>
        </div>

        <section class="live-chat-card hidden" id="chatCard">
          <div class="chat-partner-bar">
            <div class="partner-info">
              <span class="partner-avatar" id="partnerAvatar">🙂</span>
              <span class="partner-name" id="partnerName">Looking for someone…</span>
            </div>
            <div class="partner-actions">
              <button type="button" class="partner-action-btn" aria-label="Call" title="Coming soon">
                <span class="emoji-icon">📞</span>
              </button>
              <button type="button" class="partner-action-btn" aria-label="Video call" title="Coming soon">
                <span class="emoji-icon">🎥</span>
              </button>
              <button type="button" class="partner-action-btn" aria-label="More options" title="Coming soon">
                <span class="emoji-icon">⋮</span>
              </button>
            </div>
          </div>

          <p class="status sr-only" id="statusText" aria-live="polite">Looking for a partner...</p>
          <span class="timer-badge hidden" id="timerBadge"></span>

          <div class="messages" id="messages"></div>

          <div class="chat-input-bar">
            <button class="skip-btn" id="newBtn" type="button">Skip</button>
            <button class="report-btn" id="reportBtn" type="button" aria-label="Report" title="Report">⋯</button>
            <input id="messageInput" type="text" placeholder="Type a message...">
            <button class="send-btn" id="sendBtn" type="button" aria-label="Send message">
              <span class="ui-icon icon-arrow-right"></span>
            </button>
          </div>
        </section>
      </main>

      <button id="startBtnBottom" class="floating-start-button" type="button">
        Start New Chat
        <span class="ui-icon icon-arrow-right"></span>
      </button>
    </div>

    <script>
      window.__IS_GUEST__ = <%= isGuest ? 'true' : 'false' %>;
      window.__GUEST_DURATION__ = <%= guestDurationSeconds %>;
    </script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/chat-client.js"></script>
  </body>
</html>
