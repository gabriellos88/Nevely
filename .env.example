# Runtime identity
APP_ENV=local
NODE_ENV=development
PUBLIC_ORIGIN=http://localhost:3000
PORT=3000

# Data and sessions
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/nevely
SESSION_SECRET=replace-with-at-least-32-random-characters

# Railway supplies these automatically in deployed environments.
RAILWAY_ENVIRONMENT_NAME=
RAILWAY_ENVIRONMENT_ID=
PRODUCTION_RAILWAY_ENVIRONMENT_ID=

# Email. Staging must use test mode and a @resend.dev recipient.
EMAIL_DELIVERY_MODE=disabled
RESEND_API_KEY=
RESEND_FROM=Nevely <noreply@notifications.nevely.app>
RESEND_TEST_RECIPIENT=delivered+staging@resend.dev

# Analytics and indexing stay disabled outside production.
ANALYTICS_MODE=disabled
ROBOTS_INDEXING=disabled

# Release lifecycle; see railway.json and docs/release/health-and-draining.md.
SHUTDOWN_GRACE_MS=25000
